APP_NAME="RGC - Redeemed Gospel Church Inc. Tanzania Management Platform"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app
APP_KEY=base64:generate-this-once
# Keep APP_URL aligned with your live Railway/custom domain so signed receipt links stay valid.

APP_LOCALE=sw
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

RGC_SUPER_ADMIN_EMAIL=superadmin@your-domain.tld
RGC_SUPER_ADMIN_PASSWORD=change-this-before-first-seed
AUTH_API_TOKEN_EXPIRE_MINUTES=1440

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=your-railway-mysql-host
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=your-railway-mysql-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_COOKIE=rgc_platform_session

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
CACHE_STORE=database
CACHE_PREFIX=rgc_platform

# Upload persistence for the current Railway plan:
# Option A (recommended for this project right now): attach a persistent Railway volume and keep local uploads
FILESYSTEM_DISK=public

# Option B: move to S3-compatible object storage later if you want external durable uploads
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your_r2_access_key_id
# AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=your-r2-bucket
# AWS_URL=
# AWS_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS=noreply@rgc.or.tz
MAIL_FROM_NAME="RGC Platform"

SNIPPE_BASE_URL=https://api.snippe.sh
SNIPPE_API_KEY=your_snippe_api_key
SNIPPE_WEBHOOK_SECRET=your_snippe_webhook_secret
SNIPPE_TIMEOUT=15
SNIPPE_PAYMENT_FLOW=mobile_prompt

VITE_APP_NAME="${APP_NAME}"
