APP_NAME="RGC - Redeemed Gospel Church Inc. Tanzania Management Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Production: set APP_ENV=production, APP_DEBUG=false, and APP_URL to your real HTTPS domain.
# Signed public receipt links and public storage URLs depend on APP_URL being correct.

APP_LOCALE=sw
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

RGC_SUPER_ADMIN_EMAIL=superadmin@your-domain.tld
RGC_SUPER_ADMIN_PASSWORD=change-this-before-first-seed
AUTH_API_TOKEN_EXPIRE_MINUTES=1440

APP_MAINTENANCE_DRIVER=file
# Production on multiple servers: APP_MAINTENANCE_DRIVER=cache
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production suggestion: LOG_LEVEL=info
# Railway/container suggestion: LOG_STACK=stderr so platform logs collect Laravel output directly.

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rgc_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_COOKIE=rgc_platform_session
# Production over HTTPS: SESSION_SECURE_COOKIE=true
# Production suggestion: SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=database
CACHE_PREFIX=rgc_platform

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS="noreply@rgc.or.tz"
MAIL_FROM_NAME="RGC Platform"
# Production suggestion: switch MAIL_MAILER to smtp or failover and set real SMTP credentials.
# Railway suggestion: use LOG_STACK=stderr and APP_URL=https://<your-domain>.up.railway.app until your custom domain is live.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

SNIPPE_BASE_URL=https://api.snippe.sh
SNIPPE_API_KEY=
SNIPPE_WEBHOOK_SECRET=
SNIPPE_TIMEOUT=15
# mobile_prompt = send a phone payment prompt from inside the app
# checkout_session = fall back to hosted checkout links
SNIPPE_PAYMENT_FLOW=mobile_prompt

# Optional hardened browser policy.
# Leave empty locally. In production, enable only after testing every page carefully.
# SECURITY_CSP=default-src 'self'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; connect-src 'self' https:; font-src 'self' data: https:;

# Production uploads: use FILESYSTEM_DISK=s3 on Railway if you need files to survive redeploys, or attach a persistent volume before keeping public/local storage in production.
VITE_APP_NAME="${APP_NAME}"
